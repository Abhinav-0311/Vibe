# App
NEXT_PUBLIC_APP_URL=http://localhost:3005

# AI report generation
# Add a real key only in your local .env file or deployment secret store.
OPENAI_API_KEY=sk-placeholder
# AI enhancement is opt-in so local scans do not create unexpected API usage.
OPENAI_REPORT_ENABLED=false
OPENAI_REPORT_MODEL=gpt-5.4-mini

# Database persistence
# Docker Compose example: postgresql://postgres:postgres@localhost:5433/vibe?schema=public
# Native PostgreSQL example: postgresql://postgres:YOUR_PASSWORD@localhost:5432/vibe?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# GitHub OAuth
# Callback URL: http://localhost:3005/api/github/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Use a random value containing at least 32 characters.
GITHUB_TOKEN_ENCRYPTION_KEY=

# Future observability layer
SENTRY_DSN=
